{
  "name": "cypress-api-automation",
  "version": "1.0.0",
  "description": "Production-grade Cypress API automation framework using cy.request() with AJV schema validation",
  "author": "Bhuvesh Yadav <https://github.com/bhuvesh75>",
  "license": "MIT",
  "scripts": {
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:smoke": "cypress run --spec 'cypress/e2e/smoke/**/*.cy.js'",
    "cy:functional": "cypress run --spec 'cypress/e2e/functional/**/*.cy.js'",
    "cy:regression": "cypress run --spec 'cypress/e2e/regression/**/*.cy.js'"
  },
  "devDependencies": {
    "ajv": "8.13.0",
    "ajv-formats": "^3.0.1",
    "cypress": "13.10.0",
    "mochawesome": "7.1.3",
    "mochawesome-merge": "4.3.0",
    "mochawesome-report-generator": "6.2.0"
  }
}
